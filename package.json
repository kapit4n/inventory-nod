{
  "name": "server",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "db:migrate": "sequelize-cli db:migrate",
    "db:seed": "sequelize-cli db:seed:all",
    "db:reset": "sequelize-cli db:migrate:undo:all && sequelize-cli db:migrate && sequelize-cli db:seed:all",
    "prestart": "sequelize-cli db:migrate",
    "start": "node ./bin/www"
  },
  "dependencies": {
    "cookie-parser": "~1.4.4",
    "cors": "^2.8.5",
    "debug": "~2.6.9",
    "express": "~4.16.1",
    "http-errors": "~1.6.3",
    "jade": "~1.11.0",
    "morgan": "~1.9.1",
    "sequelize": "^6.6.2",
    "sqlite3": "^5.1.7",
    "swagger-ui-express": "^4.3.0"
  },
  "devDependencies": {
    "sequelize-cli": "^6.6.2"
  }
}
